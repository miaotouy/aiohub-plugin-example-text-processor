{
  "id": "example-text-processor",
  "name": "示例文本处理器",
  "version": "1.0.0",
  "description": "一个简单的文本处理插件示例，用于演示插件系统的功能",
  "author": "AIO Hub Team",
  "icon": "📝",
  "tags": ["示例", "文本处理", "工具"],
  "host": {
    "appVersion": ">=0.4.6",
    "apiVersion": 2
  },
  "type": "javascript",
  "main": "index.ts",
  "settingsSchema": {
    "version": "1.0.0",
    "properties": {
      "prefix": {
        "type": "string",
        "default": "",
        "label": "文本前缀",
        "description": "处理文本时自动添加的前缀"
      },
      "suffix": {
        "type": "string",
        "default": "",
        "label": "文本后缀",
        "description": "处理文本时自动添加的后缀"
      },
      "enablePrefix": {
        "type": "boolean",
        "default": true,
        "label": "启用前缀/后缀",
        "description": "是否在处理文本时应用前缀和后缀"
      },
      "defaultCase": {
        "type": "string",
        "default": "upper",
        "label": "默认大小写",
        "description": "默认的大小写转换方式",
        "enum": ["upper", "lower", "none"]
      }
    }
  },
  "permissions": [],
  "ui": {
    "displayName": "文本处理器",
    "component": "TextProcessor.vue",
    "icon": "📝"
  }
}