{
  "id": "example-text-processor",
  "name": "示例文本处理器",
  "version": "1.0.0",
  "description": "一个简单的文本处理插件示例，用于演示插件系统的功能",
  "author": "AIO Hub Team",
  "icon": "📝",
  "tags": ["示例", "文本处理", "工具"],
  "host": {
    "appVersion": ">=0.4.6",
    "apiVersion": 2
  },
  "type": "javascript",
  "main": "index.ts",
  "settingsSchema": {
    "version": "2.0.0",
    "properties": {
      "prefix": {
        "id": "prefix",
        "label": "文本前缀",
        "component": "ElInput",
        "modelPath": "prefix",
        "hint": "处理文本时自动添加的前缀",
        "defaultValue": "",
        "layout": "block",
        "props": {
          "placeholder": "请输入文本前缀"
        },
        "keywords": "prefix 文本前缀 前缀"
      },
      "suffix": {
        "id": "suffix",
        "label": "文本后缀",
        "component": "ElInput",
        "modelPath": "suffix",
        "hint": "处理文本时自动添加的后缀",
        "defaultValue": "",
        "layout": "block",
        "props": {
          "placeholder": "请输入文本后缀"
        },
        "keywords": "suffix 文本后缀 后缀"
      },
      "enablePrefix": {
        "id": "enablePrefix",
        "label": "启用前缀/后缀",
        "component": "ElSwitch",
        "modelPath": "enablePrefix",
        "hint": "是否在处理文本时应用前缀和后缀",
        "defaultValue": true,
        "layout": "inline",
        "keywords": "enablePrefix 启用前缀 启用后缀 开关"
      },
      "defaultCase": {
        "id": "defaultCase",
        "label": "默认大小写",
        "component": "ElSelect",
        "modelPath": "defaultCase",
        "hint": "默认的大小写转换方式",
        "defaultValue": "upper",
        "layout": "block",
        "props": {
          "placeholder": "请选择默认大小写"
        },
        "options": [
          {
            "label": "大写",
            "value": "upper"
          },
          {
            "label": "小写",
            "value": "lower"
          },
          {
            "label": "不转换",
            "value": "none"
          }
        ],
        "keywords": "defaultCase 默认大小写 大小写转换"
      }
    }
  },
  "permissions": [],
  "ui": {
    "displayName": "文本处理器",
    "component": "TextProcessor.vue",
    "icon": "📝"
  }
}