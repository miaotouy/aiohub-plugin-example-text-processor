{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": ".",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["index.ts"],
  "exclude": ["node_modules", "dist", "*.js"]
}